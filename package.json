{
  "name": "winwinstone",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:site": "turbo dev --filter=site",
    "dev:admin": "turbo dev --filter=admin",
    "build:site": "turbo build --filter=site",
    "build:admin": "turbo build --filter=admin",
    "deploy:site": "cd apps/site && vercel",
    "deploy:admin": "cd apps/admin && vercel",
    "deploy:site:prod": "cd apps/site && vercel --prod",
    "deploy:admin:prod": "cd apps/admin && vercel --prod"
  },
  "devDependencies": {
    "turbo": "^2"
  },
  "packageManager": "pnpm@10.6.4"
}
